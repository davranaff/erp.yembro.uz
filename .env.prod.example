COMPOSE_PROJECT_NAME=yembro-prod

APP_ENVIRONMENT=production
APP_NAME=yembro-backend
APP_LOG_LEVEL=INFO
APP_DEBUG=false
LOG_LEVEL=INFO

APP_DATABASE_URL=postgresql://yembro_prod:change-me@postgres:5432/yembro_prod
DATABASE_URL=postgresql://yembro_prod:change-me@postgres:5432/yembro_prod
APP_REDIS_URL=redis://:change-me@redis:6379/0
REDIS_URL=redis://:change-me@redis:6379/0

POSTGRES_USER=yembro_prod
POSTGRES_PASSWORD=change-me
POSTGRES_DB=yembro_prod
REDIS_PASSWORD=change-me

APP_POSTGRES_POOL_MIN_SIZE=1
APP_POSTGRES_POOL_MAX_SIZE=20
APP_REQUEST_TIMEOUT_SECONDS=30
REQUEST_TIMEOUT_SECONDS=30

APP_AUTH_SECRET_KEY=change-me
APP_AUTH_ACCESS_TOKEN_TTL_MINUTES=720
APP_AUTH_REFRESH_TOKEN_TTL_DAYS=30
APP_AUTH_ALLOW_HEADER_OVERRIDES=false

APP_PUBLIC_WEB_BASE_URL=https://app.example.com
APP_MEDICINE_QR_TOKEN_TTL_DAYS=365

APP_STORAGE_BACKEND=local
APP_STORAGE_LOCAL_ROOT=/data/uploads
APP_STORAGE_MAX_UPLOAD_BYTES=10485760

BACKEND_IMAGE=ghcr.io/your-org/your-repo/backend:production
FRONTEND_IMAGE=ghcr.io/your-org/your-repo/frontend:production

POSTGRES_VOLUME_NAME=postgres_data_prod
REDIS_VOLUME_NAME=redis_data_prod
UPLOADS_VOLUME_NAME=uploads_prod
INTERNAL_NETWORK_NAME=yembro_prod_internal
PUBLIC_NETWORK_NAME=yembro_prod_public

BACKUP_ROOT=/opt/yembro/backups/prod
