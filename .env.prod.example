COMPOSE_PROJECT_NAME=yembro-prod

# ── Django backend ───────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=erp.yembro.uz,api.erp.yembro.uz,localhost,127.0.0.1
APP_ENVIRONMENT=production

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=yembro_prod
POSTGRES_PASSWORD=change-me
POSTGRES_DB=yembro_prod
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me
CELERY_BROKER_URL=redis://:change-me@redis:6379/0
CELERY_RESULT_BACKEND=django-db

# ── CORS / public URLs ───────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://erp.yembro.uz
PUBLIC_WEB_BASE_URL=https://erp.yembro.uz

# ── Storage ──────────────────────────────────────────────────────────────────
APP_STORAGE_LOCAL_ROOT=/data/uploads

# ── Deployment images (overwritten by .release.env on deploy) ────────────────
BACKEND_IMAGE=registry.example.com/yembro/backend:production
FRONTEND_IMAGE=registry.example.com/yembro/frontend:production

# ── Docker volumes and networks ──────────────────────────────────────────────
POSTGRES_VOLUME_NAME=postgres_data_prod
REDIS_VOLUME_NAME=redis_data_prod
UPLOADS_VOLUME_NAME=uploads_prod
INTERNAL_NETWORK_NAME=yembro_prod_internal
PUBLIC_NETWORK_NAME=yembro_prod_public

# ── Backups ──────────────────────────────────────────────────────────────────
BACKUP_ROOT=/opt/yembro/backups/prod
