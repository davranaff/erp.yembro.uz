COMPOSE_PROJECT_NAME=yembro-staging

# ── Django backend ───────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=staging.erp.yembro.uz,staging.api.erp.yembro.uz,staging-api,localhost,127.0.0.1
APP_ENVIRONMENT=staging

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=yembro_staging
POSTGRES_PASSWORD=change-me
POSTGRES_DB=yembro_staging
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me
CELERY_BROKER_URL=redis://:change-me@redis:6379/0
CELERY_RESULT_BACKEND=django-db

# ── CORS / public URLs ───────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://staging.erp.yembro.uz
PUBLIC_WEB_BASE_URL=https://staging.erp.yembro.uz

# ── Storage ──────────────────────────────────────────────────────────────────
APP_STORAGE_LOCAL_ROOT=/data/uploads

# ── Deployment images (overwritten by .release.env on deploy) ────────────────
BACKEND_IMAGE=registry.example.com/yembro/backend:staging
FRONTEND_IMAGE=registry.example.com/yembro/frontend:staging

# ── Docker volumes and networks ──────────────────────────────────────────────
POSTGRES_VOLUME_NAME=postgres_data_staging
REDIS_VOLUME_NAME=redis_data_staging
UPLOADS_VOLUME_NAME=uploads_staging
INTERNAL_NETWORK_NAME=yembro_staging_internal
PUBLIC_NETWORK_NAME=yembro_staging_public

# ── Backups ──────────────────────────────────────────────────────────────────
BACKUP_ROOT=/opt/yembro/backups/staging
