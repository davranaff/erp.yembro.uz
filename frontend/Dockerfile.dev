FROM node:22-alpine
WORKDIR /app

# Pre-install deps in the image so first start is fast even when the bind
# mount overrides /app. The named volume on /app/node_modules keeps these.
COPY package.json package-lock.json* ./
RUN npm ci

ENV NEXT_TELEMETRY_DISABLED=1
EXPOSE 3000

# On every start: if the host bind-mount shadowed node_modules (or the
# anonymous volume is fresh), reinstall; then run Next dev.
# `npx next dev` is used directly to bypass NODE_OPTIONS=--no-webstorage
# baked into package.json scripts (Node rejects that flag).
CMD ["sh", "-c", "if [ ! -x node_modules/.bin/next ]; then npm ci; fi && exec npx next dev --turbopack -H 0.0.0.0 -p 3000"]
